# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Copy this file to ".env" for local `vercel dev`, and add the same variables in
# Vercel → Project → Settings → Environment Variables for production.

# Your Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where booking/contact notifications are delivered.
OWNER_EMAIL=n.bianchi1998@gmail.com

# The "from" sender. Until you verify your own domain in Resend, keep the shared
# test sender below (note: in test mode Resend only delivers to your own Resend
# account email). Once your domain is verified, switch to e.g.:
#   FROM_EMAIL=Aloha Massage <no-reply@yourdomain.com>
FROM_EMAIL=Aloha Massage <onboarding@resend.dev>
